# ============================================================
# Cinematic Sentiment & Trend Engine — Environment Variables
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real credentials below.
# 3. NEVER commit the .env file to version control.
# ============================================================

# ------ TMDB API ------------------------------------------
# Obtain a free v3 API key at: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ------ Google Gemini API ---------------------------------
# Obtain an API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ------ Supabase / PostgreSQL ------------------------------
# Connection string format:
#   postgresql://<user>:<password>@<host>:<port>/<database>
# Find this in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
